<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.0"?>
<plugin>

     <extension
         point="org.eclipse.core.contenttype.contentTypes">
      <content-type
            base-type="org.eclipse.core.runtime.xml"
            file-extensions="xml"
            id="hbmxmlsource"
            name="Hibernate Mapping Content-Type"
            priority="normal">
         <describer class="org.eclipse.core.runtime.content.XMLRootElementContentDescriber">
            <parameter
                  name="element"
                  value="hibernate-mapping"/>
         </describer>
      </content-type>
      <content-type
            base-type="org.eclipse.core.runtime.xml"
            file-extensions="xml"
            file-names="hibernate.cfg.xml"
            id="cfgxmlsource"
            name="Hibernate Configuration Content-type"
            priority="low">
            <describer class="org.eclipse.core.runtime.content.XMLRootElementContentDescriber">
            <parameter
                  name="element"
                  value="hibernate-configuration"/>
         </describer>
      </content-type>
	  <content-type
            base-type="org.eclipse.core.runtime.xml"
            file-extensions="xml"
            id="revengxmlsource"
            name="Hibernate Reverse Engineering Override Content-type"
            priority="high">
            <describer class="org.eclipse.core.runtime.content.XMLRootElementContentDescriber">
            <parameter
                  name="element"
                  value="hibernate-reverse-engineering"/>
         </describer>
      </content-type>
   </extension>
   <extension
         point="org.eclipse.wst.sse.core.modelHandler">
         <modelHandler
               associatedContentTypeId="org.hibernate.tool.eclipse.orm.xml.core.hbmxmlsource"
               class="org.hibernate.eclipse.mapper.modelhandler.ModelHandlerForHBMXML"
               default="false"
               id="org.hibernate.tool.eclipse.orm.xml.core.handler.hbm.xml">
         </modelHandler>
         <modelHandler
               associatedContentTypeId="org.hibernate.tool.eclipse.orm.xml.core.cfgxmlsource"
               class="org.hibernate.eclipse.mapper.modelhandler.ModelHandlerForCFGXML"
               default="false"
               id="org.hibernate.tool.eclipse.orm.xml.core.handler.cfg.xml">
         </modelHandler>
         <modelHandler
               associatedContentTypeId="org.hibernate.tool.eclipse.orm.xml.core.revengxmlsource"
               class="org.hibernate.eclipse.mapper.modelhandler.ModelHandlerForREVENGXML"
               default="false"
               id="org.hibernate.tool.eclipse.orm.xml.core.handler.reveng.xml">
         </modelHandler>
         <modelHandler
               associatedContentTypeId="org.eclipse.jpt.core.content.persistence"
               class="org.hibernate.eclipse.mapper.modelhandler.ModelHandlerForPersistenceUnitXML"
               default="false"
               id="org.hibernate.tool.eclipse.orm.xml.core.handler.persistenceunit.xml">
         </modelHandler>
   </extension>
    <extension point = "org.eclipse.wst.xml.core.catalogContributions">
       <catalogContribution>
           <public publicId="-//Hibernate/Hibernate Mapping DTD 3.0//EN"
	  		   uri="platform:/plugin/org.hibernate.tool.eclipse.orm.xml.core/dtd/hibernate-mapping-3.0.dtd"
			   webURL="http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd"/>
           <public publicId="-//Hibernate/Hibernate Configuration DTD 3.0//EN"
               uri="platform:/plugin/org.hibernate.tool.eclipse.orm.xml.core/dtd/hibernate-configuration-3.0.dtd"
               webURL="http://hibernate.sourceforge.net/hibernate-configuration-3.0.dtd"/>
           <public
               publicId="-//Hibernate/Hibernate Reverse Engineering DTD 3.0//EN"
               uri="platform:/plugin/org.hibernate.tool.eclipse.orm.xml.core/dtd/hibernate-reverse-engineering-3.0.dtd"/>
       </catalogContribution>
    </extension>

</plugin>
